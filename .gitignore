cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Virtual environment
venv/
.venv/
env/

# Dashboard runtime cache (rebuilt on launch)
dashboard_cache.joblib

# Large data file (>1GB, share via Drive)
data/song_data.db

# Model files >100MB (GitHub limit) — share via Drive
models/rf_model.joblib
models/rf_tuned.joblib
models/all_classifier_results.joblib
models/notebook_state.joblib

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
EOF
echo "wrote .gitignore"



package_submission.sh